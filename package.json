{
  "name": "auto-slip",
  "version": "1.7.5",
  "description": "월마감 전표 자동화 데스크톱 앱",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "electron-store": "^10.0.1",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0",
    "fast-xml-parser": "^5.8.0",
    "lucide-react": "^1.16.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.6.1",
    "tesseract.js": "^7.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^35.2.1",
    "electron-builder": "^25.1.8",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^3.2.1",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.autoslip.app",
    "productName": "AutoSlip",
    "publish": [
      {
        "provider": "github",
        "owner": "jjiinn04",
        "repo": "auto-slip-electron",
        "releaseType": "release"
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "resources/ocr",
        "to": "ocr"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "**/@napi-rs/**",
      "**/tesseract.js/**",
      "**/tesseract.js-core/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "installerLanguages": [
        "ko"
      ],
      "language": "1042"
    }
  }
}
